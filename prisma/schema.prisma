// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id           String        @id @default(cuid())
  name         String
  email        String
  company      String?
  service      String
  message      String?
  phone        String?
  notes        String?       @db.Text
  status       String        @default("IN_REVIEW") // IN_REVIEW, PROCESSED, CONTACTED, BOOKED
  aiProposal   String?       @db.Text

  appointments Appointment[]
  client       Client?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Keyword {
  id            String   @id @default(cuid())
  term          String   @unique
  volume        Int?     @default(0)
  difficulty    Int?     @default(0)
  currentRank   Int?
  targetRank    Int?     @default(1)
  status        String   @default("TRACKING") // TRACKING, GENERATING, PUBLISHED
  contentUrl    String?
  content       String?  @db.Text
  slug          String?  @unique
  isPublic      Boolean  @default(false)
  lastChecked   DateTime @default(now())


  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model Appointment {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  date      DateTime
  timeSlot  String
  status    String   @default("CONFIRMED") // CONFIRMED, CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

model Document {
  id        String          @id @default(cuid())
  name      String
  type      String          // pdf, txt, docx
  size      Int
  status    String          @default("UPLOADED") // UPLOADED, PROCESSING, READY, ERROR
  content   String?         // Full text content if small
  chunks    DocumentChunk[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  embedding  Json?    // Fallback if pgvector is not available
  createdAt  DateTime @default(now())

  @@index([documentId])
}

model TokenUsage {
  id               String   @id @default(cuid())
  feature          String   // e.g., "SEO_CONTENT", "CHAT", "VOICE"
  model            String   // e.g., "gpt-4o", "gpt-3.5-turbo"
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCost    Float    @default(0)
  createdAt        DateTime @default(now())
}

model Settings {
  id          String   @id @default("global")
  senderName  String   @default("Luis Lazo")
  senderEmail String   @default("luis@datalazo.net")
  agencyName  String   @default("Datalazo LLC")
  updatedAt   DateTime @updatedAt
}

model MarketingLead {
  id                 String    @id @default(cuid())
  name               String?   // Contact person's name
  email              String    // Contact email
  phone              String?   // Contact phone number
  company            String?   // Business/Company name
  website            String?   // Company website URL
  address            String?   // Physical location/address
  category           String?   // Business industry/category (e.g. "Plumbing", "Dentist")
  notes              String?   @db.Text // Any scraped remarks or raw notes
  status             String    @default("NEW") // STATUSES: NEW, GENERATING, DRAFT_READY, SENT, FAILED
  aiSubject          String?   @db.Text // AI generated cold outreach subject line
  aiBody             String?   @db.Text // AI generated cold outreach body draft
  apifyRunId         String?   // References the Apify scraper execution run
  apifyActorId       String?   // References the Apify actor used
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([email])
  @@index([status])
}

model Client {
  id               String       @id @default(cuid())
  leadId           String?      @unique
  lead             Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  name             String
  email            String       @unique
  phone            String?
  company          String?
  services         String
  software         String?
  paymentDate      DateTime?
  totalPayment     Float        @default(0.0)
  notes            String?      @db.Text
  
  stripeCustomerId String?      @unique
  stripeSubId      String?      @unique
  stripeStatus     String?      
  recurringAmount  Float?    

  // Subdomain / Tenant Slug identifier (e.g. "clientA" for clientA.datalazo.net)
  subdomain        String?      @unique

  // Relations
  users            ClientUser[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model ClientUser {
  id                     String    @id @default(cuid())
  clientId               String
  client                 Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  username               String    @unique
  password               String    // Hashed password
  termsAccepted          Boolean   @default(false)
  termsAcceptedAt        DateTime?
  termsAcceptedIp        String?
  termsAcceptedUserAgent String?
  monthlyUsageActual     Int       @default(0)   // Actual monthly tokens/usage
  monthlyUsagePrevious    Int       @default(0)   // Previous month's usage
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  logins                 ClientUserLogin[]

  @@index([clientId])
}

model ClientUserLogin {
  id        String     @id @default(cuid())
  userId    String
  user      ClientUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  createdAt DateTime   @default(now())

  @@index([userId])
}


model Invoice {
  id             String   @id @default(cuid())
  invoiceNumber  Int      @unique
  clientId       String?
  clientName     String
  clientEmail    String
  clientCompany  String?
  clientPhone    String?
  items          Json     // List of items [{description: string, amount: number}]
  amount         Float
  terms          String?  @db.Text
  status         String   @default("CREATED") // CREATED, EMAILED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  username  String
  site      String
  ipAddress String
  userAgent String
  createdAt DateTime @default(now())
}


