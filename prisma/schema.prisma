// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id           String        @id @default(cuid())
  name         String
  email        String
  company      String?
  service      String
  message      String?
  phone        String?
  notes        String?       @db.Text
  status       String        @default("IN_REVIEW") // IN_REVIEW, PROCESSED, CONTACTED, BOOKED
  aiProposal   String?       @db.Text

  appointments Appointment[]
  client       Client?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Keyword {
  id            String   @id @default(cuid())
  term          String   @unique
  volume        Int?     @default(0)
  difficulty    Int?     @default(0)
  currentRank   Int?
  targetRank    Int?     @default(1)
  status        String   @default("TRACKING") // TRACKING, GENERATING, PUBLISHED
  contentUrl    String?
  content       String?  @db.Text
  slug          String?  @unique
  isPublic      Boolean  @default(false)
  lastChecked   DateTime @default(now())


  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model Appointment {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  date      DateTime
  timeSlot  String
  status    String   @default("CONFIRMED") // CONFIRMED, CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

model Document {
  id        String          @id @default(cuid())
  name      String
  type      String          // pdf, txt, docx
  size      Int
  status    String          @default("UPLOADED") // UPLOADED, PROCESSING, READY, ERROR
  content   String?         // Full text content if small
  chunks    DocumentChunk[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  embedding  Json?    // Fallback if pgvector is not available
  createdAt  DateTime @default(now())

  @@index([documentId])
}

model TokenUsage {
  id               String   @id @default(cuid())
  feature          String   // e.g., "SEO_CONTENT", "CHAT", "VOICE"
  model            String   // e.g., "gpt-4o", "gpt-3.5-turbo"
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCost    Float    @default(0)
  createdAt        DateTime @default(now())
}

model Settings {
  id          String   @id @default("global")
  senderName  String   @default("Luis Lazo")
  senderEmail String   @default("luis@datalazo.net")
  agencyName  String   @default("Datalazo Intelligence")
  updatedAt   DateTime @updatedAt
}

model MarketingLead {
  id                 String    @id @default(cuid())
  name               String?   // Contact person's name
  email              String    // Contact email
  phone              String?   // Contact phone number
  company            String?   // Business/Company name
  website            String?   // Company website URL
  address            String?   // Physical location/address
  category           String?   // Business industry/category (e.g. "Plumbing", "Dentist")
  notes              String?   @db.Text // Any scraped remarks or raw notes
  status             String    @default("NEW") // STATUSES: NEW, GENERATING, DRAFT_READY, SENT, FAILED
  aiSubject          String?   @db.Text // AI generated cold outreach subject line
  aiBody             String?   @db.Text // AI generated cold outreach body draft
  apifyRunId         String?   // References the Apify scraper execution run
  apifyActorId       String?   // References the Apify actor used
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([email])
  @@index([status])
}

model Client {
  id               String    @id @default(cuid())
  leadId           String?   @unique
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  name             String
  email            String    @unique
  phone            String?
  company          String?
  services         String
  paymentDate      DateTime?
  totalPayment     Float     @default(0.0)
  notes            String?   @db.Text
  
  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique
  stripeStatus     String?   
  recurringAmount  Float?    

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}


