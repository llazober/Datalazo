// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id           String        @id @default(cuid())
  name         String
  email        String
  company      String?
  service      String
  message      String?
  phone        String?
  notes        String?       @db.Text
  status       String        @default("IN_REVIEW") // IN_REVIEW, PROCESSED, CONTACTED, BOOKED


  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Keyword {
  id            String   @id @default(cuid())
  term          String   @unique
  volume        Int?     @default(0)
  difficulty    Int?     @default(0)
  currentRank   Int?
  targetRank    Int?     @default(1)
  status        String   @default("TRACKING") // TRACKING, GENERATING, PUBLISHED
  contentUrl    String?
  content       String?  @db.Text
  lastChecked   DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


model Appointment {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  date      DateTime
  timeSlot  String
  status    String   @default("CONFIRMED") // CONFIRMED, CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

model Document {
  id        String          @id @default(cuid())
  name      String
  type      String          // pdf, txt, docx
  size      Int
  status    String          @default("UPLOADED") // UPLOADED, PROCESSING, READY, ERROR
  content   String?         // Full text content if small
  chunks    DocumentChunk[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  embedding  Json?    // Fallback if pgvector is not available
  createdAt  DateTime @default(now())

  @@index([documentId])
}
